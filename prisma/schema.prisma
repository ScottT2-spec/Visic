generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "wasm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  emailVerified    DateTime?
  passwordHash     String?
  firstName        String
  lastName         String
  phone            String?
  avatar           String?
  role             UserRole          @default(MERCHANT)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts         Account[]
  notifications    Notification[]
  sessions         Session[]
  siteMembers      SiteMember[]
  workspaceMembers WorkspaceMember[]
  workspaces       Workspace[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workspace {
  id        String            @id @default(cuid())
  ownerId   String
  name      String
  slug      String            @unique
  logo      String?
  plan      WorkspacePlan     @default(FREE)
  status    WorkspaceStatus   @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  sites     Site[]
  members   WorkspaceMember[]
  owner     User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(EDITOR)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Site {
  id                String             @id @default(cuid())
  workspaceId       String
  name              String
  slug              String             @unique
  description       String?
  logo              String?
  coverImage        String?
  siteType          SiteType           @default(ECOMMERCE)
  subdomain         String             @unique
  customDomain      String?            @unique
  currency          String             @default("NGN")
  country           String             @default("NG")
  businessType      String             @default("general")
  industry          String?
  status            SiteStatus         @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  abTests           ABTest[]
  abandonedCarts    AbandonedCart[]
  analytics         AnalyticsEvent[]
  auditLogs         AuditLog[]
  automations       Automation[]
  blogs             Blog[]
  brands            Brand[]
  categories        Category[]
  contactMessages   ContactMessage[]
  coupons           Coupon[]
  crmContacts       CrmContact[]
  customers         Customer[]
  deliveryZones     DeliveryZone[]
  domains           Domain[]
  emailCampaigns    EmailCampaign[]
  flashSales        FlashSale[]
  forms             Form[]
  funnels           Funnel[]
  loyaltyProgram    LoyaltyProgram?
  media             MediaItem[]
  orders            Order[]
  pages             Page[]
  paymentGateways   PaymentGateway[]
  popups            Popup[]
  products          Product[]
  referralProgram   ReferralProgram?
  returns           Return[]
  customizations    SiteCustomization?
  members           SiteMember[]
  notifications     SiteNotification[]
  plugins           SitePlugin[]
  settings          SiteSettings?
  socialLinks       SiteSocialLinks?
  templates         SiteTemplate[]
  themes            SiteTheme[]
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  smsCampaigns      SmsCampaign[]
  taxRules          TaxRule[]
  whatsappCampaigns WhatsAppCampaign[]
  wishlists         Wishlist[]

  @@index([workspaceId])
  @@index([subdomain])
  @@index([customDomain])
  @@index([siteType])
  @@map("sites")
}

model SiteMember {
  id        String         @id @default(cuid())
  siteId    String
  userId    String
  role      SiteMemberRole @default(STAFF)
  createdAt DateTime       @default(now())
  site      Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@map("site_members")
}

model SiteSettings {
  id                 String  @id @default(cuid())
  siteId             String  @unique
  allowGuestCheckout Boolean @default(true)
  payOnDelivery      Boolean @default(true)
  bankTransfer       Boolean @default(true)
  whatsappOrdering   Boolean @default(true)
  showStockCount     Boolean @default(false)
  lowDataMode        Boolean @default(false)
  offlineMode        Boolean @default(false)
  language           String  @default("en")
  whatsappNumber     String?
  metaTitle          String?
  metaDescription    String?
  googleAnalyticsId  String?
  facebookPixelId    String?
  tiktokPixelId      String?
  customHeadCode     String?
  customBodyCode     String?
  site               Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("site_settings")
}

model SiteSocialLinks {
  id        String  @id @default(cuid())
  siteId    String  @unique
  whatsapp  String?
  instagram String?
  facebook  String?
  twitter   String?
  tiktok    String?
  linkedin  String?
  youtube   String?
  site      Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("site_social_links")
}

model SiteCustomization {
  id                 String    @id @default(cuid())
  siteId             String    @unique
  themeSettings      Json?
  pageSettings       Json?
  sectionSettings    Json?
  blockSettings      Json?
  navigationSettings Json?
  footerSettings     Json?
  headerSettings     Json?
  mediaAssets        Json?
  seoSettings        Json?
  revisionHistory    Json?
  customCss          String?
  customJs           String?
  currentVersion     Int       @default(1)
  publishedVersion   Int       @default(1)
  lastPublishedAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  site               Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("site_customizations")
}

model Domain {
  id                String       @id @default(cuid())
  siteId            String
  domain            String       @unique
  type              DomainType   @default(CUSTOM)
  status            DomainStatus @default(PENDING)
  sslStatus         SSLStatus    @default(PENDING)
  sslExpiresAt      DateTime?
  dnsVerified       Boolean      @default(false)
  verificationToken String?
  isPrimary         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  site              Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("domains")
}

model Brand {
  id          String    @id @default(cuid())
  siteId      String
  name        String
  slug        String
  logo        String?
  description String?
  website     String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([siteId, slug])
  @@index([siteId])
  @@map("brands")
}

model Category {
  id          String     @id @default(cuid())
  siteId      String
  name        String
  slug        String
  description String?
  image       String?
  parentId    String?
  position    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  site        Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([siteId, slug])
  @@index([siteId])
  @@map("categories")
}

model Product {
  id                String             @id @default(cuid())
  siteId            String
  categoryId        String?
  brandId           String?
  name              String
  slug              String
  description       String?
  price             Decimal            @db.Decimal(12, 2)
  compareAtPrice    Decimal?           @db.Decimal(12, 2)
  costPrice         Decimal?           @db.Decimal(12, 2)
  currency          String             @default("NGN")
  sku               String?
  barcode           String?
  stock             Int                @default(0)
  lowStockAlert     Int                @default(5)
  trackInventory    Boolean            @default(true)
  weight            Decimal?           @db.Decimal(8, 2)
  productType       ProductType        @default(PHYSICAL)
  status            ProductStatus      @default(DRAFT)
  isFeatured        Boolean            @default(false)
  tags              String[]
  metaTitle         String?
  metaDescription   String?
  position          Int                @default(0)
  downloadUrl       String?
  downloadLimit     Int?
  recurringInterval String?
  recurringPrice    Decimal?           @db.Decimal(12, 2)
  trialDays         Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  flashSales        FlashSaleProduct[]
  orderItems        OrderItem[]
  images            ProductImage[]
  variants          ProductVariant[]
  brand             Brand?             @relation(fields: [brandId], references: [id])
  category          Category?          @relation(fields: [categoryId], references: [id])
  site              Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  reviews           Review[]
  wishlists         WishlistItem[]

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([siteId, status])
  @@index([siteId, categoryId])
  @@index([siteId, brandId])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  name       String
  sku        String?
  price      Decimal?    @db.Decimal(12, 2)
  stock      Int         @default(0)
  image      String?
  options    Json
  position   Int         @default(0)
  createdAt  DateTime    @default(now())
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model Order {
  id               String          @id @default(cuid())
  siteId           String
  customerId       String?
  orderNumber      String          @unique
  email            String
  phone            String?
  status           OrderStatus     @default(PENDING)
  paymentStatus    PaymentStatus   @default(PENDING)
  paymentMethod    String?
  paymentReference String?
  subtotal         Decimal         @db.Decimal(12, 2)
  deliveryFee      Decimal         @default(0) @db.Decimal(12, 2)
  discount         Decimal         @default(0) @db.Decimal(12, 2)
  tax              Decimal         @default(0) @db.Decimal(12, 2)
  total            Decimal         @db.Decimal(12, 2)
  currency         String          @default("NGN")
  couponId         String?
  note             String?
  deliveryAddress  Json?
  deliveryMethod   String?
  deliveryZoneId   String?
  trackingNumber   String?
  whatsappNotified Boolean         @default(false)
  cancelReason     String?
  paidAt           DateTime?
  shippedAt        DateTime?
  deliveredAt      DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  recoveredCart    AbandonedCart?  @relation("RecoveredCart")
  items            OrderItem[]
  timeline         OrderTimeline[]
  coupon           Coupon?         @relation(fields: [couponId], references: [id])
  customer         Customer?       @relation(fields: [customerId], references: [id])
  site             Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  referral         Referral?
  returns          Return[]

  @@index([siteId])
  @@index([siteId, status])
  @@index([siteId, createdAt])
  @@index([customerId])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  productId   String?
  variantId   String?
  name        String
  variantName String?
  sku         String?
  price       Decimal         @db.Decimal(12, 2)
  quantity    Int
  total       Decimal         @db.Decimal(12, 2)
  image       String?
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderTimeline {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  note      String?
  createdBy String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_timeline")
}

model Return {
  id           String       @id @default(cuid())
  siteId       String
  orderId      String
  reason       String
  status       ReturnStatus @default(REQUESTED)
  refundAmount Decimal?     @db.Decimal(12, 2)
  refundMethod String?
  items        Json?
  notes        String?
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  site         Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([orderId])
  @@map("returns")
}

model Customer {
  id                 String          @id @default(cuid())
  siteId             String
  email              String
  firstName          String
  lastName           String
  phone              String?
  address            Json?
  tags               String[]
  note               String?
  totalOrders        Int             @default(0)
  totalSpent         Decimal         @default(0) @db.Decimal(12, 2)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  abandonedCarts     AbandonedCart[]
  affiliates         Affiliate[]
  site               Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  loyaltyMemberships LoyaltyMember[]
  orders             Order[]
  reviews            Review[]
  wishlists          Wishlist[]

  @@unique([siteId, email])
  @@index([siteId])
  @@map("customers")
}

model Wishlist {
  id         String         @id @default(cuid())
  siteId     String
  customerId String
  sessionId  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  items      WishlistItem[]
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  site       Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, customerId])
  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  addedAt    DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@map("wishlist_items")
}

model Review {
  id         String    @id @default(cuid())
  productId  String
  customerId String?
  name       String
  email      String
  rating     Int
  title      String?
  body       String?
  images     String[]
  isVerified Boolean   @default(false)
  isApproved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  customer   Customer? @relation(fields: [customerId], references: [id])
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("reviews")
}

model Coupon {
  id             String     @id @default(cuid())
  siteId         String
  code           String
  type           CouponType
  value          Decimal    @db.Decimal(12, 2)
  minOrderAmount Decimal?   @db.Decimal(12, 2)
  maxUses        Int?
  usedCount      Int        @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  site           Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  orders         Order[]

  @@unique([siteId, code])
  @@index([siteId])
  @@map("coupons")
}

model TaxRule {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  rate      Decimal  @db.Decimal(5, 2)
  country   String?
  state     String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("tax_rules")
}

model PaymentGateway {
  id            String               @id @default(cuid())
  siteId        String
  provider      PaymentProvider
  isEnabled     Boolean              @default(false)
  publicKey     String?
  secretKey     String?
  webhookSecret String?
  config        Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  site          Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  transactions  PaymentTransaction[]

  @@unique([siteId, provider])
  @@index([siteId])
  @@map("payment_gateways")
}

model PaymentTransaction {
  id          String            @id @default(cuid())
  gatewayId   String
  orderId     String?
  reference   String            @unique
  externalRef String?
  amount      Decimal           @db.Decimal(12, 2)
  currency    String            @default("NGN")
  status      TransactionStatus @default(PENDING)
  method      String?
  metadata    Json?
  paidAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  gateway     PaymentGateway    @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@index([gatewayId])
  @@index([reference])
  @@index([orderId])
  @@map("payment_transactions")
}

model DeliveryZone {
  id            String   @id @default(cuid())
  siteId        String
  name          String
  areas         String[]
  fee           Decimal  @db.Decimal(12, 2)
  freeAbove     Decimal? @db.Decimal(12, 2)
  estimatedDays String?
  isActive      Boolean  @default(true)
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("delivery_zones")
}

model Theme {
  id            String            @id @default(cuid())
  name          String
  slug          String            @unique
  description   String?
  thumbnail     String?
  preview       String?
  category      String
  industry      String?
  isPremium     Boolean           @default(false)
  isFeatured    Boolean           @default(false)
  isActive      Boolean           @default(true)
  config        Json
  version       String            @default("1.0.0")
  tags          String[]
  installs      Int               @default(0)
  rating        Decimal           @default(0) @db.Decimal(3, 2)
  price         Decimal?          @db.Decimal(12, 2)
  authorId      String?
  isAIGenerated Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  marketplace   MarketplaceItem[]
  siteThemes    SiteTheme[]

  @@map("themes")
}

model SiteTheme {
  id           String   @id @default(cuid())
  siteId       String
  themeId      String
  isActive     Boolean  @default(false)
  customConfig Json?
  installedAt  DateTime @default(now())
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  theme        Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@unique([siteId, themeId])
  @@index([siteId])
  @@map("site_themes")
}

model Template {
  id                     String         @id @default(cuid())
  name                   String
  slug                   String         @unique
  category               String
  description            String?
  previewImage           String?
  previewUrl             String?
  recommendationKeywords String[]
  themeConfig            Json
  variants               Json?
  active                 Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  siteTemplates          SiteTemplate[]

  @@index([category])
  @@index([active])
  @@map("templates")
}

model SiteTemplate {
  id          String   @id @default(cuid())
  siteId      String
  templateId  String
  variant     String?
  themeConfig Json
  pages       Json?
  isActive    Boolean  @default(true)
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customHtml  String?
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([siteId, templateId])
  @@index([siteId])
  @@index([templateId])
  @@map("site_templates")
}

model Plugin {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  description   String?
  icon          String?
  category      String
  author        String
  version       String             @default("1.0.0")
  isPremium     Boolean            @default(false)
  isActive      Boolean            @default(true)
  config        Json?
  entryPoint    String?
  permissions   String[]
  installs      Int                @default(0)
  rating        Decimal            @default(0) @db.Decimal(3, 2)
  price         Decimal?           @db.Decimal(12, 2)
  isAIGenerated Boolean            @default(false)
  reviewStatus  PluginReviewStatus @default(APPROVED)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  marketplace   MarketplaceItem[]
  sitePlugins   SitePlugin[]

  @@map("plugins")
}

model SitePlugin {
  id          String   @id @default(cuid())
  siteId      String
  pluginId    String
  isEnabled   Boolean  @default(true)
  config      Json?
  settings    Json?
  installedAt DateTime @default(now())
  plugin      Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, pluginId])
  @@index([siteId])
  @@map("site_plugins")
}

model Page {
  id              String   @id @default(cuid())
  siteId          String
  title           String
  slug            String
  type            PageType @default(CUSTOM)
  content         Json?
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  position        Int      @default(0)
  template        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  abTests         ABTest[]
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId])
  @@map("pages")
}

model Blog {
  id              String     @id @default(cuid())
  siteId          String
  title           String
  slug            String
  excerpt         String?
  content         Json?
  contentHtml     String?
  coverImage      String?
  author          String?
  category        String?
  tags            String[]
  status          BlogStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  site            Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([siteId, status])
  @@map("blogs")
}

model Form {
  id               String           @id @default(cuid())
  siteId           String
  name             String
  slug             String
  description      String?
  fields           Json
  settings         Json?
  submitButtonText String           @default("Submit")
  successMessage   String?
  isActive         Boolean          @default(true)
  submissionCount  Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  submissions      FormSubmission[]
  site             Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId])
  @@map("forms")
}

model FormSubmission {
